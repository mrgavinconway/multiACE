	{% else %}
	MOVE_TO_XY_IDLE_POSITION_EXTRUDER X_OFFSET=-1.5 Y_OFFSET=50.5 {rawparams}
	{% endif %}

[gcode_macro SHAPER_CALIBRATE]
rename_existing = SHAPER_CALIBRATE_BASE
gcode = 
	SHAPER_CALIBRATE_BASE {rawparams}
	SAVE_CONFIG RESTART=0

[gcode_macro PRINT_START]
gcode = 
	{% for i in range(printer.configfile.settings.printer.max_physical_extruder_num) %}
	SET_GCODE_VARIABLE MACRO=SM_PRINT_START_LINE_EXTRUDER_{i} VARIABLE=has_finished VALUE=False
	FLOW_APPLY_CALIBRATE_K EXTRUDER={i}
	{% endfor %}
	
	M84
	G92 E0
	M220 S100

[gcode_macro PRINT_STRAT]
gcode = 
	
	PRINT_START

[gcode_macro PRINT_END]
gcode = 
	M220 S100
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE'] | default({}) %}
	{% set retract = client.cancel_retract | default(5.0) | abs %}
	{% set move_z_max_heigh = client.move_z_max_heigh | default(270.5) | abs %}
	
	
	_CLIENT_RETRACT LENGTH={retract}
	
	{% set current_pos = printer.gcode_move.gcode_position %}
	{% set delta_z = 0.0 %}
	{% if "z" in printer.toolhead.homed_axes %}
	{% if current_pos.z < move_z_max_heigh - 2.0 %}
	{% set delta_z = 2.0 %}
	{% elif current_pos.z < move_z_max_heigh %}
	{% set delta_z = move_z_max_heigh - current_pos.z %}
	{% else %}
	{% set delta_z = 0.0 %}
	{% endif %}
	G91
	G0 Z{delta_z} F2000
	{% endif %}
	{% if "xy" in printer.toolhead.homed_axes %}
	PARK_EXTRUDER
	G90
	G0 X5 Y5 F3000
	{% else %}
	RESPOND TYPE=echo MSG='Printer not homed XY'
	{% endif %}
	
	{% if "z" in printer.toolhead.homed_axes %}
	{% if current_pos.z < 200 %}
	G90
	G0 Z200 F2000
	{% elif current_pos.z < 265 %}
	G91
	G0 Z3 F2000
	{% endif %}
	G90
	{% else %}
	RESPOND TYPE=echo MSG='Printer not homed Z'
	{% endif %}
	
	TURN_OFF_HEATERS
	M107
	M107 P2 S0
	SET_PURIFIER_MODE MODE=0
	
	SET_PAUSE_NEXT_LAYER ENABLE=0
	SET_PAUSE_AT_LAYER ENABLE=0 LAYER=0
	M84
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=is_pause_on_err VALUE=False
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=pos_e_compensation VALUE=False
	SET_IDLE_TIMEOUT TIMEOUT={printer.configfile.settings.idle_timeout.timeout}

[gcode_macro CANCEL_PRINT]
description = Cancel the actual running print
rename_existing = CANCEL_PRINT_BASE
gcode = 
	M220 S100
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE'] | default({}) %}
	{% set retract = client.cancel_retract | default(5.0) | abs %}
	{% set move_z_max_heigh = client.move_z_max_heigh | default(270.5) | abs %}
	
	
	_CLIENT_RETRACT LENGTH={retract}
	{% set current_pos = printer.gcode_move.gcode_position %}
	{% set delta_z = 0.0 %}
	
	{% if "z" in printer.toolhead.homed_axes %}
	{% if current_pos.z < 200 %}
	G90
	G0 Z200 F2000
	{% elif current_pos.z < 265 %}
	G91
	G0 Z5 F2000
	{% else %}
	{% if current_pos.z < move_z_max_heigh - 2.0 %}
	{% set delta_z = 2.0 %}
	{% elif current_pos.z < move_z_max_heigh %}
	{% set delta_z = move_z_max_heigh - current_pos.z %}
	{% else %}
	{% set delta_z = 0.0 %}
	{% endif %}
	G91
	G0 Z{delta_z} F2000
	{% endif %}
	G90
	{% else %}
	RESPOND TYPE=echo MSG='Printer not homed Z'
	{% endif %}
	
	CANCEL_PRINT_BASE
	TURN_OFF_HEATERS
	SET_PURIFIER_MODE MODE=0
	M107
	M107 P2 S0
	
	SET_PAUSE_NEXT_LAYER ENABLE=0
	SET_PAUSE_AT_LAYER ENABLE=0 LAYER=0
	M84
	TIMELAPSE_STOP
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=is_pause_on_err VALUE=False
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=pos_e_compensation VALUE=False
	SET_IDLE_TIMEOUT TIMEOUT={printer.configfile.settings.idle_timeout.timeout}

[gcode_macro INNER_PAUSE]
description = Pause the actual running print
variable_pause_temp = 40
gcode = 
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE'] | default({}) %}
	{% set move_z_max_heigh = client.move_z_max_heigh | default(270.5) | abs %}
	
	
	
	{% set extruder = printer[printer.toolhead.extruder].extruder_index %}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=last_extruder_index VALUE={extruder}
	{% set temp = printer[printer.toolhead.extruder].target if printer.toolhead.extruder != '' else 0 %}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=last_extruder_temp VALUE={temp}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=extruder0_temp VALUE={printer['extruder'].target}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=extruder1_temp VALUE={printer['extruder1'].target}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=extruder2_temp VALUE={printer['extruder2'].target}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=extruder3_temp VALUE={printer['extruder3'].target}
	
	PAUSE_BASE
	_CLIENT_RETRACT
	
	
	{% if params.ON_ERROR | default(0) | int == 0 %}
	{% set current_pos = printer.gcode_move.gcode_position %}
	{% set delta_z = 0.0 %}
	{% if current_pos.z < move_z_max_heigh - 5.0 %}
	{% set delta_z = 5.0 %}
	{% elif current_pos.z < move_z_max_heigh %}
	{% set delta_z = move_z_max_heigh - current_pos.z %}
	{% else %}
	{% set delta_z = 0.0 %}
	{% endif %}
	{% if "xyz" in printer.toolhead.homed_axes %}
	MOVE_TO_DISCARD_FILAMENT_POSITION SPEED=500 ACCEL=10000 Z_OFFSET={delta_z}
	{% else %}
	RESPOND TYPE=echo MSG='Printer not homed'
	{% endif %}
	{% endif %}
	
	{% if params.IS_RUNOUT | default(0) | int != 0 %}
	{% if "xyz" in printer.toolhead.homed_axes %}
	{% if printer[printer.toolhead.extruder].target >= 170 %}
	M109 S{printer[printer.toolhead.extruder].target}
	M83
	G1 E10 F150
	_CLIENT_RETRACT
	{% endif %}
	{% endif %}
	{% endif %}
	
	M400
	
	{% if printer['print_stats'].state == 'printing' %}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=pos_e_compensation VALUE=True
	{% endif %}
	
	{% if printer['extruder'].target > 0 %}
	M104 S{pause_temp} T0 A0
	{% endif %}
	{% if printer['extruder1'].target > 0 %}
	M104 S{pause_temp} T1 A0
	{% endif %}
	{% if printer['extruder2'].target > 0 %}
	M104 S{pause_temp} T2 A0
	{% endif %}
	{% if printer['extruder3'].target > 0 %}
	M104 S{pause_temp} T3 A0
	{% endif %}
	
	{% if params.IS_RUNOUT | default(0) | int != 0 %}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=is_runout VALUE=1
	FEEDING_RUNOUT_EVENT_HANDLE EXTRUDER={extruder}
	
	{% elif params.ON_ERROR | default(0) | int != 0 %}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=is_pause_on_err VALUE=True
	
	{% endif %}
	
	
	M107
	M107 P2
	M107 P3
	
	
	SET_IDLE_TIMEOUT TIMEOUT={printer.configfile.settings.idle_timeout.timeout_on_pause}
	
	
	GET_POSITION
	M118 extruder0 temp : {printer['extruder'].target}
	M118 extruder1 temp : {printer['extruder1'].target}
	M118 extruder2 temp : {printer['extruder2'].target}
	M118 extruder3 temp : {printer['extruder3'].target}
	M118 bed temp : {printer['heater_bed'].target}
	M118 last extruder index : {last_extruder_index}

[gcode_macro INNER_RESUME]
description = Resume the actual running print (multiACE override)
variable_last_extruder_index = 0
variable_last_extruder_temp = 0
variable_extruder0_temp = 0
variable_extruder1_temp = 0
variable_extruder2_temp = 0
variable_extruder3_temp = 0
variable_is_pause_on_err = False
variable_is_runout = 0
variable_flow_calibrating = False
variable_flow_calibrate_temp = 220
variable_pos_e_compensation = False
gcode = 
	{% set client = printer['gcode_macro _CLIENT_VARIABLE'] | default({}) %}
	{% set velocity = printer.configfile.settings.pause_resume.recover_velocity %}
	{% set sp_move = client.speed_move | default(velocity) %}
	{% set unretract = client.unretract | default(0.0) %}
	{% set retract = client.retract | default(5.0) | abs %}
	{% set can_resume = True %}
	{% set error_id = 522 %}
	{% set error_index = 0 %}
	{% set error_code = 0 %}
	{% set error_message = "resume error" %}
	{% set is_homed_z_before_paused = True %}
	{% set is_filament_exist = True %}
	{% set e_pos = 0 %}
	{% set is_replenish = params.REPLENISH | default(0) | int %}
	{% if is_replenish != 0 %}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=last_extruder_index VALUE={params.REPLENISH_EXTRUDER}
	{% set last_extruder_index = params.REPLENISH_EXTRUDER | default(last_extruder_index) | int %}
	{% endif %}
	{% if last_extruder_index == 0 %}
	{% set e_pos = printer['extruder'].printing_e_pos | float | abs %}
	{% else %}
	{% set e_pos = printer['extruder%d' % (last_extruder_index)].printing_e_pos | float | abs %}
	{% endif %}
	{% if pos_e_compensation %}
	{% if e_pos >= retract %}
	{% set e_pos = e_pos - retract %}
	{% else %}
	{% set e_pos = 0 %}
	{% endif %}
	{% endif %}
	{% if retract >= e_pos %}
	{% if unretract >= e_pos %}
	{% set unretract = unretract - e_pos %}
	{% else %}
	{% set unretract = 0 %}
	{% endif %}
	{% else %}
	{% set retract = e_pos + retract - unretract %}
	{% set unretract = 0 %}
	{% endif %}
	{% set runout_sensor_name = "e%d_filament" % (last_extruder_index)  %}
	{% set runout_sensor = "filament_motion_sensor e%d_filament" % (last_extruder_index) %}
	{% if "z" not in printer.toolhead.homed_axes %}
	{% set is_homed_z_before_paused = False %}
	{% endif %}
	{% if printer.print_task_config['filament_exist'][last_extruder_index] == False %}
	{% set is_filament_exist = False %}
	{% endif %}
	{% if is_replenish == 0 and is_filament_exist == True %}
	INNER_CHECK_AND_RELOAD_FILAMENT_INFO EXTRUDER={last_extruder_index} IS_RUNOUT={is_runout}
	{% endif %}
	{% if is_filament_exist == False %}
	{% set can_resume = False %}
	{% endif %}
	{% if can_resume == True %}
	{% if is_replenish != 0 %}
	SET_ACTION_CODE ACTION=PRINT_REPLENISHING
	{% else %}
	SET_ACTION_CODE ACTION=PRINT_RESUMING
	{% endif %}
	M118 last extruder temp is {last_extruder_temp}, last extruder index is {last_extruder_index}
	{% if is_pause_on_err and last_extruder_temp >= 170 %}
	M104 S{last_extruder_temp} T{last_extruder_index} A0
	M109 S{last_extruder_temp} T{last_extruder_index} A0
	{% endif %}
	{% if is_pause_on_err and "z" in printer.toolhead.homed_axes %}
	G91
	G1 Z10 F600
	G90
	{% endif %}
	{% if is_pause_on_err or "xy" not in printer.toolhead.homed_axes %}
	G28 X Y
	{% endif %}
	T{last_extruder_index} A0
	SM_PRINT_AUTO_FEED EXTRUDER={last_extruder_index}
	MOVE_TO_DISCARD_FILAMENT_POSITION
	{% if is_homed_z_before_paused == True %}
	G4 P200
	M400
	CHECK_FILAMENT_RUNOUT SENSOR={runout_sensor_name}
	M107
	M104 S{extruder0_temp} T0 A0
	M104 S{extruder1_temp} T1 A0
	M104 S{extruder2_temp} T2 A0
	M104 S{extruder3_temp} T3 A0
	SET_IDLE_TIMEOUT TIMEOUT={printer.configfile.settings.idle_timeout.timeout_on_pause}
	{% if extruder0_temp >= 170 %}
	M109 S{extruder0_temp} T0 A0
	{% endif %}
	{% if extruder1_temp >= 170 %}
	M109 S{extruder1_temp} T1 A0
	{% endif %}
	{% if extruder2_temp >= 170 %}
	M109 S{extruder2_temp} T2 A0
	{% endif %}
	{% if extruder3_temp >= 170 %}
	M109 S{extruder3_temp} T3 A0
	{% endif %}
	{% if last_extruder_temp > 170 %}
	M109 S{last_extruder_temp} T{last_extruder_index} A0
	INNER_APPLY_FLOW_K EXTRUDER={printer.toolhead.extruder} APPLY=1
	_CLIENT_EXTRUDE LENGTH=20 SPEED=2
	INNER_APPLY_FLOW_K EXTRUDER={printer.toolhead.extruder} APPLY=0
	_CLIENT_RETRACT LENGTH={retract}
	M400
	M106 S255
	{% else %}
	M106 S255
	M109 S{last_extruder_temp} T{last_extruder_index} A0
	{% set unretract = 0.0 %}
	{% endif %}
	M204 S10000
	M106 S255
	INNER_CUTOFF_BASE_DISCARD
	INNER_ROUGHLY_CLEAN_NOZZLE_BASE_DISCARD
	INNER_DISCARD_FILAMENT_BASE_DISCARD
	G90
	G1 Y250 F6000
	CHECK_FILAMENT_RUNOUT SENSOR={runout_sensor_name}
	RESUME_BASE VELOCITY={params.VELOCITY | default(sp_move)} MOVE_ACCEL=10000 EXTRUDE={unretract}
	{% else %}
	RESUME_BASE VELOCITY={params.VELOCITY | default(sp_move)} MOVE=0
	{% endif %}
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=is_pause_on_err VALUE=False
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=pos_e_compensation VALUE=False
	SET_GCODE_VARIABLE MACRO=INNER_RESUME VARIABLE=is_runout VALUE=0
	{% else %}
	{% if is_filament_exist == False %}
	{% set error_id = 523 %}
	{% set error_index = last_extruder_index %}
	{% set error_code = 0 %}
	{% set error_message = "e%d filament runout" % (last_extruder_index) %}
	{% else %}
	{% set error_id = 522 %}
	{% set error_index = 0 %}
	{% set error_code = 0 %}
	{% set error_message = "resume error" %}
	{% endif %}
	RAISE_EXCEPTION ID={error_id} INDEX={error_index} CODE={error_code} MSG='{"%s" % error_message}' LEVEL=2
	{% endif %}
	SET_ACTION_CODE ACTION=IDLE

[gcode_macro SET_PAUSE_NEXT_LAYER]
description = Enable a pause if the next layer is reached
gcode = 
	{% set pause_next_layer = printer['gcode_macro SET_PRINT_STATS_INFO'].pause_next_layer %}
	{% set ENABLE = params.ENABLE | default(1)|int != 0 %}
	{% set MACRO = params.MACRO | default(pause_next_layer.call, True) %}
	SET_GCODE_VARIABLE MACRO=SET_PRINT_STATS_INFO VARIABLE=pause_next_layer VALUE="{{ 'enable': ENABLE, 'call': MACRO }}"

[gcode_macro SET_PAUSE_AT_LAYER]
description = Enable/disable a pause if a given layer number is reached
gcode = 
	{% set pause_at_layer = printer['gcode_macro SET_PRINT_STATS_INFO'].pause_at_layer %}
	{% set ENABLE = params.ENABLE | int != 0 if params.ENABLE is defined
	else params.LAYER is defined %}
	{% set LAYER = params.LAYER | default(pause_at_layer.layer) | int %}
	{% set MACRO = params.MACRO | default(pause_at_layer.call, True) %}
	SET_GCODE_VARIABLE MACRO=SET_PRINT_STATS_INFO VARIABLE=pause_at_layer VALUE="{{ 'enable': ENABLE, 'layer': LAYER, 'call': MACRO }}"

[gcode_macro SET_PRINT_STATS_INFO]
rename_existing = SET_PRINT_STATS_INFO_BASE
description = Overwrite, to get pause_next_layer and pause_at_layer feature
variable_pause_next_layer = { 'enable': False, 'call': "PAUSE" }
variable_pause_at_layer = { 'enable': False, 'layer': 0, 'call': "PAUSE" }
gcode = 
	{% if pause_next_layer.enable %}
	RESPOND TYPE=echo MSG='{"%s, forced by pause_next_layer" % pause_next_layer.call}'
	{pause_next_layer.call}
	SET_PAUSE_NEXT_LAYER ENABLE=0
	{% elif pause_at_layer.enable and params.CURRENT_LAYER is defined and params.CURRENT_LAYER | int == pause_at_layer.layer %}
	RESPOND TYPE=echo MSG='{"%s, forced by pause_at_layer [%d]" % (pause_at_layer.call, pause_at_layer.layer)}'
	{pause_at_layer.call}
	SET_PAUSE_AT_LAYER ENABLE=0
	{% endif %}
	SET_PRINT_STATS_INFO_BASE {rawparams}

[gcode_macro _CLIENT_EXTRUDE]
description = Extrudes, if the extruder is hot enough
gcode = 
	
	{% set client = printer['gcode_macro _CLIENT_VARIABLE'] | default({}) %}
	{% set use_fw_retract = (client.use_fw_retract | default(false) | lower == 'true') and (printer.firmware_retraction is defined) %}
	{% set length = params.LENGTH | default(client.unretract) | default(1.0) | float %}
	{% set speed = params.SPEED | default(client.speed_unretract) | default(35) %}
	{% set absolute_extrude = printer.gcode_move.absolute_extrude %}
	
	{% if printer.toolhead.extruder != '' %}
	{% if printer[printer.toolhead.extruder].can_extrude %}
	{% if use_fw_retract %}
	{% if length < 0 %}
	G10
	{% else %}
	G11
	{% endif %}
	{% else %}
	M83
	G1 E{length} F{(speed | float | abs) * 60}
	{% if absolute_extrude %}
	M82
	{% endif %}
	{% endif %}
	{% else %}
	RESPOND TYPE=echo MSG='{"\"%s\" not hot enough" % printer.toolhead.extruder}'
	{% endif %}
	{% endif %}

[gcode_macro _CLIENT_RETRACT]
description = Retracts, if the extruder is hot enough
gcode = 
	{% set client = printer['gcode_macro _CLIENT_VARIABLE'] | default({}) %}
	{% set length = params.LENGTH | default(client.retract) | default(1.0) | float %}
	{% set speed = params.SPEED | default(client.speed_retract) | default(35) %}
	
	_CLIENT_EXTRUDE LENGTH=-{length | float | abs} SPEED={speed | float | abs}

[gcode_macro INNER_FILAMENT_UNLOAD]
gcode = 
	{% set nozzle_diameter = params.NOZZLE_DIAMETER | default(0.4) | float %}
	{% set temp = params.TEMP | default(250) | int %}
	{% set soft = params.SOFT | default(0) | int %}
	
	MOVE_TO_DISCARD_FILAMENT_POSITION
	M109 S{temp}
	CONTROL_RETRACT_ACTION SOFT={soft}
	M400
	M104 S0
	M106 S255
	G4 P5000
	INNER_CUTOFF_BASE_DISCARD
	INNER_ROUGHLY_CLEAN_NOZZLE_BASE_DISCARD ACTION=2
	INNER_DISCARD_FILAMENT_BASE_DISCARD
	M107

[gcode_macro AUTO_FEEDING]
gcode = 
	{% set filament_feed_vars = printer['gcode_macro _FILAMENT_FEED_VARIABLE'] | default({}) %}
	{% set extruder = params.EXTRUDER | default(999) | int %}
	{% if filament_feed_vars != {} and
	extruder >= 0 and
	extruder < printer.configfile.settings.printer.max_physical_extruder_num %}
	{% set feed_module_seq = filament_feed_vars.module_sequence[extruder] %}
	{% set feed_channel_seq = filament_feed_vars.channel_sequence[extruder] %}
	FEED_AUTO MODULE={feed_module_seq} CHANNEL={feed_channel_seq} {rawparams}
	{% else %}
	{% if filament_feed_vars == {} %}
	RESPOND TYPE=error MSG='{"gcode_macro _FILAMENT_FEED_VARIABLE error!"}'
	{% else %}
	RESPOND TYPE=error MSG='{"extruder error: %d!" % (extruder)}'
	{% endif %}
	{% endif %}

