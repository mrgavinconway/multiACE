	EXTRUDER_OFFSET_ACTION_PROBE_CALIBRATE TOOL_ID=T0
	EXTRUDER_OFFSET_ACTION_PROBE_CALIBRATE TOOL_ID=T1
	EXTRUDER_OFFSET_ACTION_PROBE_CALIBRATE TOOL_ID=T2
	EXTRUDER_OFFSET_ACTION_PROBE_CALIBRATE TOOL_ID=T3
	G90
	G1 Z150 F1800

[gcode_macro _EXTRUDER_OFFSET_ACTION_PROBE_CALIBRATE_T0]
