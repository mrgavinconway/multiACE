	{% endif %}

[gcode_macro SM_PRINT_START_LINE]
gcode = 
	{% set index = params.INDEX | default(999) | int %}
	{% set target_temp = params.TARGET_TEMP | default(0) | int %}
	
	{% if index >= 0 and index < 8 and target_temp != 0 %}
	G90
	G0 Z3 F5000
	{% if printer.print_task_config['extruder_map_table'][index] == 0 %}
	SM_PRINT_START_LINE_EXTRUDER_0 {rawparams}
	{% elif printer.print_task_config['extruder_map_table'][index] == 1 %}
	SM_PRINT_START_LINE_EXTRUDER_1 {rawparams}
	{% elif printer.print_task_config['extruder_map_table'][index] == 2 %}
	SM_PRINT_START_LINE_EXTRUDER_2 {rawparams}
	{% elif printer.print_task_config['extruder_map_table'][index] == 3 %}
	SM_PRINT_START_LINE_EXTRUDER_3 {rawparams}
	{% endif %}
	{% endif %}

[gcode_macro SM_PRINT_START_LINE_EXTRUDER_0]
variable_has_finished = False
gcode = 
	{% set target_temp = params.TARGET_TEMP | default(250) | int %}
	
	{% if has_finished == False %}
	T0 A0
	G90
	G0 X10 Y3 Z2 F18000
	M109 S{target_temp}
	G1 Z0.2
	G91
	M83
	G1 X40 E15 F360
	G0 E-0.5
	G90
	G1 Z3
	SET_GCODE_VARIABLE MACRO=SM_PRINT_START_LINE_EXTRUDER_0 VARIABLE=has_finished VALUE=True
	{% endif %}

