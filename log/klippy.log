	PROBE_XYZ_OFFSET_CALIBRATE  Z_PROBE_Y_MOVE_OFFSET=-1 SAMPLE_RETRACT_DIST=1 SAMPLES_AXIS=1 SAMPLE_DIR=1 PROBE_FAST_SPEED=2 PROBE_SPEED=2 SAMPLE_DIST=20 SAMPLES_TOLERANCE=0.02 SAMPLES_TOLERANCE_RETRIES=10 SAMPLES=3 HORIZONTAL_MOVE_X=13 HORIZONTAL_MOVE_Y=234.5 HORIZONTAL_MOVE_Z=2 RETRACT_Z_HIGHT=0.7 SAMPLE_TRIG_FREQ=450 PROBE_XYZ_MODE=1 HORIZONTAL_DIST=5 PROBE_POINTS=10 WAIT_BEFORE_SETUP=0.1 WAIT_AFTER_SETUP=0.05 SAVE_INFO=1

[gcode_macro XYZ_OFFSET_CALIBRATE_ALL]
