[gcode_macro SET_ACE_MODE]
description = Switch mode. Usage: SET_ACE_MODE MODE=normal|single|multi
gcode = 
	{% set mode = params.MODE|default('')|lower %}
	{% if mode not in ['normal', 'single', 'multi'] %}
	{action_respond_info("ERROR: Use SET_ACE_MODE MODE=normal, single, or multi")}
	{% else %}
	{% set current = printer.save_variables.variables.get('ace__mode', 'normal') %}
	{% if current == mode %}
	{action_respond_info("Already in %s mode (re-syncing files)..." % mode|upper)}
	{% else %}
	{action_respond_info("Switching to %s mode..." % mode|upper)}
	{% endif %}
	{% set needs_unload = (current in ['single', 'multi'] and mode == 'normal') or (current == 'normal' and mode in ['single', 'multi']) %}
	{% if needs_unload %}
	{% set e0 = printer['filament_motion_sensor e0_filament'].filament_detected %}
	{% set e1 = printer['filament_motion_sensor e1_filament'].filament_detected %}
	{% set e2 = printer['filament_motion_sensor e2_filament'].filament_detected %}
	{% set e3 = printer['filament_motion_sensor e3_filament'].filament_detected %}
	{% set loaded = [] %}
	{% if e0 %}{% set _ = loaded.append('E0') %}{% endif %}
	{% if e1 %}{% set _ = loaded.append('E1') %}{% endif %}
	{% if e2 %}{% set _ = loaded.append('E2') %}{% endif %}
	{% if e3 %}{% set _ = loaded.append('E3') %}{% endif %}
	{% if loaded|length > 0 %}
	{action_respond_info("Cannot switch mode! Filament still loaded in: %s" % loaded|join(', '))}
	{action_respond_info("Please unload all toolheads first, then try again.")}
	{% else %}
	ACE_RUN_MODE_SWITCH MODE={mode}
	{% endif %}
	{% else %}
	ACE_RUN_MODE_SWITCH MODE={mode}
	{% endif %}
	{% endif %}

