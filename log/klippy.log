[gcode_macro SET_ACE_MODE]
description = Switch mode. Usage: SET_ACE_MODE MODE=normal|single|multi
gcode = 
	{% set mode = params.MODE|default('')|lower %}
	{% if mode not in ['normal', 'single', 'multi'] %}
	{action_respond_info("ERROR: Use SET_ACE_MODE MODE=normal, single, or multi")}
	{% else %}
	{% set current = printer.save_variables.variables.get('ace__mode', 'normal') %}
	{% if current == mode %}
	{action_respond_info("Already in %s mode (re-syncing files)..." % mode|upper)}
	{% else %}
	{action_respond_info("Switching to %s mode..." % mode|upper)}
	{% endif %}
	{% set needs_unload = (current in ['single', 'multi'] and mode == 'normal') or (current == 'normal' and mode in ['single', 'multi']) %}
	{% if needs_unload %}
	{% set e0 = printer['filament_motion_sensor e0_filament'].filament_detected %}
	{% set e1 = printer['filament_motion_sensor e1_filament'].filament_detected %}
	{% set e2 = printer['filament_motion_sensor e2_filament'].filament_detected %}
	{% set e3 = printer['filament_motion_sensor e3_filament'].filament_detected %}
	{% set loaded = [] %}
	{% if e0 %}{% set _ = loaded.append('E0') %}{% endif %}
	{% if e1 %}{% set _ = loaded.append('E1') %}{% endif %}
	{% if e2 %}{% set _ = loaded.append('E2') %}{% endif %}
	{% if e3 %}{% set _ = loaded.append('E3') %}{% endif %}
	{% if loaded|length > 0 %}
	{action_respond_info("Cannot switch mode! Filament still loaded in: %s" % loaded|join(', '))}
	{action_respond_info("Please unload all toolheads first, then try again.")}
	{% else %}
	ACE_RUN_MODE_SWITCH MODE={mode}
	{% endif %}
	{% else %}
	ACE_RUN_MODE_SWITCH MODE={mode}
	{% endif %}
	{% endif %}

[gcode_macro ACEA__Switch_0]
description = Switch to ACE 0
gcode = 
	ACE_SWITCH TARGET=0

[gcode_macro ACEA__Switch_1]
description = Switch to ACE 1
gcode = 
	ACE_SWITCH TARGET=1

[gcode_macro ACEA__Switch_2]
description = Switch to ACE 2
gcode = 
	ACE_SWITCH TARGET=2

[gcode_macro ACEA__Switch_3]
description = Switch to ACE 3
gcode = 
	ACE_SWITCH TARGET=3

[gcode_macro ACEB__Load_0]
description = Switch to ACE 0 and load all filled slots
gcode = 
	ACE_SWITCH TARGET=0 AUTOLOAD=1

[gcode_macro ACEB__Load_1]
description = Switch to ACE 1 and load all filled slots
gcode = 
	ACE_SWITCH TARGET=1 AUTOLOAD=1

[gcode_macro ACEB__Load_2]
description = Switch to ACE 2 and load all filled slots
gcode = 
	ACE_SWITCH TARGET=2 AUTOLOAD=1

[gcode_macro ACEB__Load_3]
description = Switch to ACE 3 and load all filled slots
gcode = 
	ACE_SWITCH TARGET=3 AUTOLOAD=1

[gcode_macro ACEC__Unload_All]
description = Unload all toolheads that have filament
gcode = 
	ACE_UNLOAD_ALL_HEADS

[gcode_macro ACEC__Unload_T0]
description = Unload T0 back to its ACE
gcode = 
	ACE_UNLOAD_HEAD HEAD=0

[gcode_macro ACEC__Unload_T1]
description = Unload T1 back to its ACE
gcode = 
	ACE_UNLOAD_HEAD HEAD=1

[gcode_macro ACEC__Unload_T2]
description = Unload T2 back to its ACE
gcode = 
	ACE_UNLOAD_HEAD HEAD=2

[gcode_macro ACEC__Unload_T3]
description = Unload T3 back to its ACE
gcode = 
	ACE_UNLOAD_HEAD HEAD=3

[gcode_macro ACEC__Load_T0]
description = Load T0 from active ACE
gcode = 
	ACE_LOAD_HEAD HEAD=0

[gcode_macro ACEC__Load_T1]
description = Load T1 from active ACE
gcode = 
	ACE_LOAD_HEAD HEAD=1

[gcode_macro ACEC__Load_T2]
description = Load T2 from active ACE
gcode = 
	ACE_LOAD_HEAD HEAD=2

[gcode_macro ACEC__Load_T3]
description = Load T3 from active ACE
gcode = 
	ACE_LOAD_HEAD HEAD=3

[gcode_macro ACED__Dry_Start_0]
description = Start drying on ACE 0 (uses config temp/duration)
gcode = 
	ACE_DRY ACE=0

[gcode_macro ACED__Dry_Start_1]
description = Start drying on ACE 1 (uses config temp/duration)
gcode = 
	ACE_DRY ACE=1

[gcode_macro ACED__Dry_Start_2]
description = Start drying on ACE 2 (uses config temp/duration)
gcode = 
	ACE_DRY ACE=2

[gcode_macro ACED__Dry_Start_3]
description = Start drying on ACE 3 (uses config temp/duration)
gcode = 
	ACE_DRY ACE=3

[gcode_macro ACED__Dry_Stop]
description = Stop drying on current ACE
gcode = 
	ACE_STOP_DRYING

[gcode_macro ACEF__Mode_Normal]
description = Switch to Normal mode (stock feeders, no ACE)
gcode = 
	SET_ACE_MODE MODE=normal

[gcode_macro ACEF__Mode_Multi]
description = Switch to MultiACE mode
gcode = 
	SET_ACE_MODE MODE=multi

[gcode_macro ACEG__Status]
description = Show active ACE, detected devices, and head mapping
gcode = 
	ACE_HEAD_STATUS

[gcode_macro ACEG__List]
description = List all detected ACE devices
gcode = 
	ACE_LIST

[gcode_macro ACEH__Update_Check]
description = Check GitHub for a newer multiACE release (no install)
gcode = 
	ACE_UPDATE_CHECK

[gcode_macro ACEH__Update_Apply]
description = Download + install the latest multiACE release
gcode = 
	ACE_UPDATE_APPLY

